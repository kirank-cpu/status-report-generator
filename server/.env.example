# ─── Server environment ──────────────────────────────────────────────────────
# Copy to `.env` for local overrides, or set these in your host's dashboard.

# Port the API/SPA server listens on (hosts usually set this automatically).
# PORT=3001

# Turso (production database). Get these from `turso db show` / `turso db tokens
# create`, or the Turso dashboard. When BOTH are set the app uses Turso; when
# unset it falls back to a local SQLite file (dev/test).
# TURSO_DATABASE_URL=libsql://your-db-name-you.turso.io
# TURSO_AUTH_TOKEN=your-token

# Local SQLite file path (only used when TURSO_DATABASE_URL is unset).
# MSR_DB_FILE=./msr.db

# ─── Password-reset email (forgot-password flow) ─────────────────────────────
# Base URL used to build reset links in emails. In production set this to your
# public site, e.g. https://status-report-generator.onrender.com. If unset, the
# server derives it from the incoming request.
# APP_URL=https://status-report-generator.onrender.com

# Gmail SMTP. GMAIL_APP_PASSWORD is a 16-char Google App Password (needs 2-Step
# Verification enabled on the account), NOT your normal Gmail password. When
# unset, reset emails are not sent — the link is logged to the server console.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# MAIL_FROM=MSR Generator <you@gmail.com>
